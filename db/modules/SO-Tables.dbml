  soco_ordref     char(8)    [note: 'FK > sohead.soh_ordref']
  soco_suffix     smallint
  soco_delref     char(8)    [note: 'FK > sodeliv.sod_delref']
  soco_contract   char(10)
  soco_carser     char(10)
  soco_condate    date
  soco_deldate    date
  soco_confirmed  char(1)
  soco_status     smallint
  soco_receiver   char(30)
}

// ============================================================
// SUPPLIER DIRECT (SD) QUOTES
// ============================================================

Table sosdhead [note: 'Supplier direct quote header'] {
  sosdh_quotref    char(8)    [note: 'Quote reference - PK']
  sosdh_supplier   char(10)
  sosdh_customer   char(10)
  sosdh_status     char(1)
  sosdh_expiry     date
  sosdh_credate    date
  sosdh_opid       char(4)
  sosdh_supparef   char(15)   [note: "Supplier's agreed ref"]
  sosdh_suppcurr   char(4)
  sosdh_intproj    char(15)
  sosdh_extproj    char(15)
  sosdh_scomp      char(4)
  sosdh_ccomp      char(4)
}

Table sosditem [note: 'Supplier direct quote lines'] {
  sosdi_quotref    char(8)    [note: 'FK > sosdhead.sosdh_quotref']
  sosdi_lineno     smallint
  sosdi_product    char(40)
  sosdi_qqty       float      [note: 'Quoted qty']
  sosdi_qcost      float      [note: 'Quoted cost']
  sosdi_qprice     float      [note: 'Quoted sell price']
  sosdi_shipqty    float
  sosdi_shipcost   float
  sosdi_shipprice  float
  sosdi_ncost      float
  sosdi_sprice     float
  sosdi_margin     float
  sosdi_lnstat     char(1)
  sosdi_resqty     float
  sosdi_qclaimed   float
  sosdi_vclaimed   float
  sosdi_extref     char(15)
}

// ============================================================
// CLAIMS / REBATES
// ============================================================

Table soclaim [note: 'Supplier claim/rebate lines'] {
  socl_seq        smallint   [note: 'Sequence']
  socl_supplier   char(10)
  socl_customer   char(10)
  socl_ordref     char(8)    [note: 'FK > sohead.soh_ordref']
  socl_invref     char(8)    [note: 'FK > soinvoice.soinv_invref']
  socl_quotref    char(8)    [note: 'FK > sosdhead.sosdh_quotref']
  socl_batch      char(6)
  socl_clstat     integer
  socl_trandate   date
  socl_cltype     char(1)
  socl_product    char(15)
  socl_qty        float
  socl_claim      float
  socl_glclaim    float
  socl_cossal     float
