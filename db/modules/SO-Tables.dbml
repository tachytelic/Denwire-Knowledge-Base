  sore_ordtype    char(1)
  sore_customer   char(10)
  sore_product    char(15)
  sore_quantity   float
  sore_price      float
  sore_cossal     float
  sore_value      float
  sore_margin     float
  sore_profit     char(1)
  sore_reqdate    date
  sore_stopcode   char(1)
}

// ============================================================
// MASTER ORDERS (CALL-OFF / BLANKET)
// ============================================================

Table somast [note: 'Links master blanket orders to call-off sub-orders'] {
  som_master      char(8)    [note: 'FK > sohead.soh_ordref (master)']
  som_subord      char(8)    [note: 'FK > sohead.soh_ordref (call-off)']
  som_customer    char(10)
  som_record      char(1)
  som_type        char(1)
}

// ============================================================
// CONFIGURED ITEMS
// ============================================================

Table soconfig [note: 'Configured product component lines'] {
  socf_ordref     char(8)    [note: 'FK > sohead.soh_ordref']
  socf_ordline    integer    [note: 'FK > soitem.soi_seq']
  socf_seq        integer
  socf_product    char(15)
  socf_qty        float
  socf_type       char(1)
  socf_sellpr     float
  socf_cost       float
}

// ============================================================
// INVOICE EXCEPTIONS
// ============================================================

Table soinvex [note: 'Invoice plug adjustments / exceptions'] {
  sox_proof       integer
  sox_seq         integer
  sox_ordref      char(8)    [note: 'FK > sohead.soh_ordref']
  sox_invref      char(8)    [note: 'FK > soinvoice.soinv_invref']
  sox_opid        char(4)
  sox_reason      char(1)
  sox_runtime     integer
  sox_txplg1      char(40)
  sox_txplg2      char(40)
  sox_nuplg1      float
  sox_nuplg2      float
}

// ============================================================
// ITEM INDEX
// ============================================================

Table soiindex [note: 'Lightweight product index per order (fast lookup)'] {
  soii_ordref     char(8)    [note: 'FK > sohead.soh_ordref']
  soii_seq        smallint
  soii_product    char(40)
  soii_loc        char(5)
  soii_status     char(1)
}

// ============================================================
// HISTORY TABLES (mirror structure of live tables)
// ============================================================

Table sohish [note: 'Historical copy of sohead (archived orders)'] {
  sos_ordref      char(8)    [note: 'Order reference']
  sos_account     char(10)
  sos_userid      char(4)
  sos_orddate     date
  sos_reqdate     date
  sos_status      char(1)
  sos_ordtype     char(1)
  sos_repcode     char(4)
  sos_area        char(4)
  sos_currency    char(4)
  sos_ordval      float
  sos_ordcost     float
  sos_invval      float
  sos_company     char(4)
}

Table soitemh [note: 'Historical copy of soitem (archived order lines)'] {
  soz_ordref      char(8)    [note: 'FK > sohish.sos_ordref']
  soz_seq         smallint
  soz_product     char(40)
  soz_desc        char(40)
  soz_itqty       float
  soz_price       float
  soz_itcost      float
  soz_cossal      float
  soz_invval      float
  soz_itstat      char(1)
  soz_invref      char(8)
  soz_rep         char(4)
}

// ============================================================
// LOOKUP / REFERENCE TABLES
// ============================================================

Table soinvcod [note: 'Invoice type code lookup'] {
  soic_invcode    char(4)    [note: 'PK']
  soic_invdesc    char(30)
}

Table sopcodes [note: 'General SO code lookup (type+code+desc)'] {
  soc_type        char(1)    [note: 'Code type classifier']
  soc_code        char(10)   [note: 'Code value']
  soc_desc        char(40)
}

Table sodels [note: 'Delivery charge rate bands (14-tier weight breaks)'] {
  sodl_trcode     char(1)
  sodl_deldesc    char(30)
  sodl_pcode      char(40)
  sodl_area       char(4)
  sodl_pgroup     char(4)
  sodl_brk1       float
  sodl_brk2       float
  sodl_brk3       float
  sodl_del1       float
  sodl_del2       float
  sodl_del3       float
  sodl_cost1      float
  sodl_cost2      float
  sodl_cost3      float
}

Table soclink [note: 'Customer/product foreign currency link pricing'] {
  sock_type       char(1)
  sock_customer   char(10)
  sock_pcode      char(15)
  sock_linkcurr   char(5)
  sock_salecurr   char(5)
  sock_linkrate   float
  sock_cstbasis   float
  sock_uplinkvar  float
  sock_lolinkvar  float
}

Table sotcust [note: 'Temporary customer addresses (used during order entry)'] {
  sot_intern      char(10)
  sot_intdel      char(4)
  sot_exterc      char(22)
  sot_extdel      char(20)
}

// ============================================================
// RELATIONSHIPS
// ============================================================

// Order header -> lines
Ref: soitem.soi_ordref    > sohead.soh_ordref
// Order header -> delivery
Ref: sodeliv.sod_ordref   > sohead.soh_ordref
// Order header -> invoice
Ref: soinvoice.soinv_ordref > sohead.soh_ordref
// Order line -> invoice
Ref: soitem.soi_invref    > soinvoice.soinv_invref
// Order line -> delivery
Ref: soitem.soi_delref    > sodeliv.sod_delref
// Order header -> load
Ref: sohead.soh_loadno    > soload.sol_loadno
Ref: sodeliv.sod_loadno   > soload.sol_loadno
Ref: soitem.soi_loadno    > soload.sol_loadno
// Order header -> van schedule
Ref: sovan.sov_ordref     > sohead.soh_ordref
Ref: sovan.sov_delref     > sodeliv.sod_delref
// Order header -> pick
Ref: sopick.sopi_ordref   > sohead.soh_ordref
// Order header -> unpick
Ref: sounpick.soun_ordref > sohead.soh_ordref
// Order header -> comments
Ref: socomm.socom_ordref  > sohead.soh_ordref
// Order header -> payments
Ref: sopay.sopy_ordref    > sohead.soh_ordref
// Order header -> audit
Ref: soaudit.sou_ordref   > sohead.soh_ordref
// Order header -> recovery
Ref: sorecov.sore_ordref  > sohead.soh_ordref
// Order header -> consignments
Ref: socons.soco_ordref   > sohead.soh_ordref
Ref: socons.soco_delref   > sodeliv.sod_delref
// Order header -> config items
Ref: soconfig.socf_ordref > sohead.soh_ordref
// Invoice exceptions
Ref: soinvex.sox_ordref   > sohead.soh_ordref
Ref: soinvex.sox_invref   > soinvoice.soinv_invref
