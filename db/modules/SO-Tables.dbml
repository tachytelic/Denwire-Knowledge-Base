// Denwire Strategix ERP - Sales Order (SO) Tables
// Generated from Informix 7.23 "denw" database column definitions
// Note: Informix 7.23 has no enforced FK constraints - all refs are conventional
// Paste into https://dbdiagram.io to render

// ============================================================
// CORE ORDER TABLES
// ============================================================

Table sohead [note: 'Sales order header - one row per order'] {
  soh_ordref     char(8)    [note: 'Order reference - PK']
  soh_account    char(10)   [note: 'Customer account code']
  soh_userid     char(4)    [note: 'Operator who entered order']
  soh_orddate    date       [note: 'Order date']
  soh_reqdate    date       [note: 'Requested delivery date']
  soh_status     char(1)    [note: 'O=open, C=complete, H=hold etc']
  soh_ordtype    char(1)    [note: 'Order type code']
  soh_repcode    char(4)    [note: 'Sales rep code']
  soh_area       char(4)    [note: 'Sales area']
  soh_deladd     char(4)    [note: 'Delivery address code']
  soh_currency   char(4)    [note: 'Currency code']
  soh_terms      char(4)    [note: 'Payment terms']
  soh_ordval     float      [note: 'Order value (ex VAT)']
  soh_outvat     float      [note: 'VAT amount']
  soh_ordcost    float      [note: 'Total cost value']
  soh_invval     float      [note: 'Invoiced value to date']
  soh_payval     float      [note: 'Payments received']
  soh_stopcode   char(1)    [note: 'Credit stop code']
  soh_stloc      char(5)    [note: 'Default stock location']
  soh_loadno     integer    [note: 'FK > soload.sol_loadno']
  soh_company    char(4)    [note: 'Company code']
  soh_div        char(4)    [note: 'Division']
  soh_mastord    char(8)    [note: 'FK > sohead.soh_ordref (master order)']
  soh_source     char(8)    [note: 'Source order ref (e.g. quote)']
  soh_vanarea    char(4)    [note: 'Van area for delivery routing']
  soh_orddate    date
  soh_delname    char(40)   [note: 'Delivery name']
  soh_delad1     char(30)
  soh_delad2     char(30)
  soh_delad3     char(30)
  soh_delad4     char(30)
  soh_delad5     char(30)
  soh_delpost    char(10)
  soh_author     char(4)    [note: 'Authorising user']
  soh_ref1       char(15)   [note: 'Customer reference 1']
  soh_ref2       char(15)   [note: 'Customer reference 2']
  soh_pigrp      char(3)    [note: 'Pick group']
}

Table soitem [note: 'Order line items - one row per line'] {
  soi_ordref     char(8)    [note: 'FK > sohead.soh_ordref']
  soi_seq        smallint   [note: 'Line sequence (composite PK with ordref)']
  soi_linseq     smallint   [note: 'Sub-line sequence']
  soi_product    char(40)   [note: 'Product code']
  soi_desc       char(40)   [note: 'Product description']
  soi_ittype     char(1)    [note: 'Item type (S=stock, N=non-stock etc)']
  soi_itstk      char(1)    [note: 'Stock flag']
  soi_itqty      float      [note: 'Ordered quantity']
  soi_entqty     float      [note: 'Entered quantity']
  soi_adjqty     float      [note: 'Adjusted quantity']
  soi_pickqty    float      [note: 'Picked quantity']
  soi_canqty     float      [note: 'Cancelled quantity']
  soi_price      float      [note: 'Unit selling price']
  soi_basepri    float      [note: 'Base list price']
  soi_itcost     float      [note: 'Unit cost']
  soi_invval     float      [note: 'Invoiced value']
  soi_cossal     float      [note: 'Cost of sale']
  soi_discper    float      [note: 'Discount %']
  soi_vatcode    char(1)    [note: 'VAT code']
  soi_itstat     char(1)    [note: 'Line status']
  soi_stloc      char(5)    [note: 'Stock location']
  soi_bin        char(10)   [note: 'Bin location']
  soi_batch      integer    [note: 'Batch number']
  soi_invref     char(8)    [note: 'FK > soinvoice.soinv_invref']
  soi_delref     char(8)    [note: 'FK > sodeliv.sod_delref']
  soi_suffix     smallint   [note: 'Delivery suffix']
  soi_loadno     integer    [note: 'FK > soload.sol_loadno']
  soi_ndeldat    date       [note: 'Next delivery date']
  soi_reqdate    date       [note: 'Requested date']
  soi_invdate    date       [note: 'Invoice date']
  soi_despdate   date       [note: 'Despatched date']
  soi_rep        char(4)    [note: 'Rep code (can differ from header)']
  soi_supplier   char(10)   [note: 'Supplier (for direct orders)']
  soi_claim      integer    [note: 'Claim number']
  soi_quotref    char(8)    [note: 'FK > sosdhead.sosdh_quotref (SD quote)']
  soi_custprod   char(40)   [note: "Customer's product code"]
  soi_weight     float
  soi_vol        float
  soi_uom        char(1)    [note: 'Unit of measure']
  soi_vanarea    char(4)
  soi_parent     smallint   [note: 'Parent line (for config items)']
  soi_pigrp      char(3)
}

// ============================================================
// INVOICE
// ============================================================

Table soinvoice [note: 'Invoice header records'] {
  soinv_invref    char(8)    [note: 'Invoice reference - PK']
  soinv_ordref    char(8)    [note: 'FK > sohead.soh_ordref']
  soinv_account   char(10)   [note: 'Customer account']
  soinv_invdate   date       [note: 'Invoice date']
  soinv_type      char(1)    [note: 'I=invoice, C=credit note']
  soinv_doctot    float      [note: 'Document total inc VAT']
  soinv_gdstot    float      [note: 'Goods total ex VAT']
  soinv_totdisc   float      [note: 'Total discount']
  soinv_setdisc   float      [note: 'Settlement discount %']
  soinv_currency  char(4)
  soinv_vatexch   float      [note: 'VAT exchange rate']
  soinv_proof     integer    [note: 'GL posting proof number']
  soinv_glbatch   char(6)    [note: 'GL batch reference']
  soinv_vatc1     char(1)
  soinv_vatc2     char(1)
  soinv_vatc3     char(1)
  soinv_vatc4     char(1)
  soinv_vatc5     char(1)
  soinv_gds1      float
  soinv_gds2      float
  soinv_gds3      float
  soinv_gds4      float
  soinv_gds5      float
  soinv_vat1      float
  soinv_vat2      float
  soinv_vat3      float
  soinv_vat4      float
  soinv_vat5      float
}

// ============================================================
// DELIVERY
// ============================================================

Table sodeliv [note: 'Delivery consignment header'] {
  sod_delref      char(8)    [note: 'Delivery reference - PK']
  sod_ordref      char(8)    [note: 'FK > sohead.soh_ordref']
  sod_account     char(10)   [note: 'Customer account']
  sod_suffix      smallint   [note: 'Order suffix']
  sod_pikloc      char(5)    [note: 'Pick location']
  sod_pickdat     date       [note: 'Pick date']
  sod_delstat     smallint   [note: 'Delivery status']
  sod_deldate     date       [note: 'Delivery date']
  sod_condate     date       [note: 'Confirmed date']
  sod_carrier     char(10)   [note: 'Carrier code']
  sod_carser      char(10)   [note: 'Carrier service']
  sod_loadno      integer    [note: 'FK > soload.sol_loadno']
  sod_picker      char(10)
  sod_packer      char(10)
  sod_confirmed   char(1)
  sod_parcels     smallint
  sod_totwght     float
  sod_ccharge     float      [note: 'Carriage charge']
  sod_custref     char(20)   [note: 'Customer delivery ref']
  sod_delname     char(40)
  sod_delad1      char(30)
  sod_delad2      char(30)
  sod_delad3      char(30)
  sod_delad4      char(30)
  sod_delad5      char(30)
  sod_delpost     char(10)
  sod_company     char(4)
}

// ============================================================
// RETURNS
// ============================================================

Table sorhead [note: 'Returns (RMA) header'] {
  sorh_retno      char(8)    [note: 'Return reference - PK']
  sorh_customer   char(10)   [note: 'Customer account']
  sorh_origso     char(8)    [note: 'FK > sohead.soh_ordref (original order)']
  sorh_soref      char(8)    [note: 'FK > sohead.soh_ordref (replacement order)']
  sorh_crref      char(8)    [note: 'FK > soinvoice.soinv_invref (credit note)']
  sorh_dateret    date       [note: 'Date returned']
  sorh_datecom    date       [note: 'Date completed']
  sorh_status     char(1)
  sorh_reason     char(4)
  sorh_repcode    char(4)
  sorh_area       char(4)
  sorh_loadno     integer    [note: 'FK > soload.sol_loadno']
  sorh_company    char(4)
  sorh_vanarea    char(4)
  sorh_auth       char(4)    [note: 'Authorising user']
  sorh_colname    char(40)   [note: 'Collection address']
  sorh_colad1     char(30)
  sorh_colad2     char(30)
  sorh_colad3     char(30)
  sorh_colad4     char(30)
  sorh_colad5     char(30)
  sorh_colpost    char(10)
}

Table soritem [note: 'Returns line items'] {
  sori_retno      char(8)    [note: 'FK > sorhead.sorh_retno']
  sori_seq        integer    [note: 'Line sequence']
  sori_product    char(40)
  sori_qty        float
  sori_uom        char(1)
  sori_loc        char(5)
  sori_bin        char(10)
  sori_costpr     float
  sori_sellpr     float
  sori_origso     char(8)    [note: 'FK > sohead.soh_ordref']
  sori_defect     char(4)
  sori_reason     char(4)
  sori_date1      date
  sori_stat1      char(1)
  sori_date2      date
  sori_stat2      char(1)
}

Table sorcomm [note: 'Returns comments'] {
  sorc_retno      char(8)    [note: 'FK > sorhead.sorh_retno']
  sorc_line       integer
  sorc_seq        integer
  sorc_text       char(50)
}

// ============================================================
// PICKING
// ============================================================

Table sopick [note: 'Pick list header'] {
  sopi_pid        integer    [note: 'Pick ID - PK']
  sopi_ordref     char(8)    [note: 'FK > sohead.soh_ordref']
  sopi_status     char(1)
  sopi_loc        char(5)
  sopi_pickdate   date
  sopi_picktime   smallfloat
  sopi_lineno     smallint
  sopi_suffix     smallint
  sopi_bulkref    integer
}

Table sounpick [note: 'Reversed pick records'] {
  soun_unqkey     serial     [note: 'PK (serial)']
  soun_ordref     char(8)    [note: 'FK > sohead.soh_ordref']
  soun_line       smallint
  soun_batch      integer
  soun_bin        char(10)
  soun_serial     char(22)
  soun_qty        float
  soun_trandate   date
}

// ============================================================
// COMMENTS
// ============================================================

Table socomm [note: 'Order line comments'] {
  socom_ordref    char(8)    [note: 'FK > sohead.soh_ordref']
  socom_ordline   smallint
