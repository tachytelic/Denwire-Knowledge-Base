  socom_comtype   char(1)
  socom_text      char(50)
}

// ============================================================
// PAYMENTS
// ============================================================

Table sopay [note: 'Order payments (cash/card/BACS)'] {
  sopy_seq        serial     [note: 'PK (serial)']
  sopy_ordref     char(8)    [note: 'FK > sohead.soh_ordref']
  sopy_payref     char(8)
  sopy_customer   char(10)
  sopy_method     char(8)    [note: 'Payment method']
  sopy_payval     float
  sopy_actdate    date
  sopy_status     char(1)
  sopy_cardnum    char(20)
  sopy_author     char(20)   [note: 'Auth code']
  sopy_batch      char(6)
  sopy_paycode    char(4)
}

// ============================================================
// AUDIT
// ============================================================

Table soaudit [note: 'Change audit trail for orders'] {
  sou_seq         integer    [note: 'Sequence - PK']
  sou_ordref      char(8)    [note: 'FK > sohead.soh_ordref']
  sou_user        char(4)
  sou_type        char(1)    [note: 'Change type']
  sou_product     char(40)
  sou_before      float
  sou_after       float
  sou_datover     date
  sou_timeover    float
  sou_account     char(10)
  sou_lineseq     smallint
  sou_ref         char(20)
}

// ============================================================
// LOAD / VAN ROUTING
// ============================================================

Table soload [note: 'Van load and route planning'] {
  sol_loadno      integer    [note: 'Load number - PK']
  sol_desdate     date       [note: 'Despatch date']
  sol_routeno     smallint
  sol_status      char(1)
  sol_rname       char(8)    [note: 'Route name']
  sol_vname       char(8)    [note: 'Vehicle name']
  sol_dname       char(16)   [note: 'Driver name']
  sol_text1       char(50)
  sol_text2       char(50)
  sol_stime       integer
}

Table sovan [note: 'Van schedule - links orders to van areas'] {
  sov_vanarea     char(4)
  sov_ordref      char(8)    [note: 'FK > sohead.soh_ordref']
  sov_suffix      smallint
  sov_delref      char(8)    [note: 'FK > sodeliv.sod_delref']
  sov_date        date
  sov_postcd      char(10)
  sov_weight      float
  sov_cubvol      float
  sov_stloc       char(5)
}

// ============================================================
